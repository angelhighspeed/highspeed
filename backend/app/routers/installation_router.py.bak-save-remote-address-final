    if plan:
        profile = get_first_attr(
            plan,
            ["mikrotik_profile", "pppoe_profile", "profile", "name"],
            "default",
        )

    return {
        "name": pppoe_username,
        "password": pppoe_password,
        "remote_address": remote_address,
        "profile": profile,
    }


def add_customer_to_mikrotik(db: Session, customer: Customer, router_id: Optional[int] = None):
    pppoe_data = get_customer_pppoe_data(db, customer)

    username = pppoe_data["name"]
    password = pppoe_data["password"]
    remote_address = pppoe_data["remote_address"]
    profile = pppoe_data["profile"]

    missing = []

    if not username:
        missing.append("usuario PPPoE")

    if not password:
        missing.append("password PPPoE")

    if not remote_address:
        missing.append("Remote Address PPPoE")

    if missing:
        return {
            "status": "skipped",
            "message": "No se agregó a MikroTik. Faltan datos: " + ", ".join(missing),
        }

    try:
        from app.services import mikrotik_service
    except Exception as e:
        return {
            "status": "error",
            "message": f"No se pudo importar mikrotik_service: {str(e)}",
        }

    secret_object = SimpleNamespace(
        name=username,
        username=username,
        password=password,
        service="pppoe",
        profile=profile or "default",
        remote_address=remote_address,
        comment=f"Cliente ID {customer.id}",
    )

    payload = {
        "name": username,
        "username": username,
        "password": password,
        "service": "pppoe",
        "profile": profile or "default",
        "remote_address": remote_address,
        "comment": f"Cliente ID {customer.id}",
    }


    if router_id:
        try:
            api, router = get_mikrotik_api_for_router(db, router_id)
            secret_resource = api.get_resource("/ppp/secret")

            secret_resource.add(
                name=username,
                password=password,
                service="pppoe",
                profile=profile or "default",
                **{
                    "remote-address": remote_address,
                    "comment": f"Cliente ID {customer.id}",
                },
            )

            return {
                "status": "ok",
                "message": f"Cliente agregado a MikroTik en {get_router_display_name(router)}",
                "result": None,
            }
        except Exception as e:
            last_direct_error = str(e)
    else:
        last_direct_error = None

    candidate_functions = [
        "create_pppoe_secret",
        "add_pppoe_secret",
        "add_mikrotik_pppoe_secret",
        "add_mikrotik_secret",
        "add_secret",
    ]

    last_error = None

    for function_name in candidate_functions:
        function = getattr(mikrotik_service, function_name, None)

        if not callable(function):
            continue

        try:
            if function_name == "create_pppoe_secret":
                result = function(secret_object)
            else:
                try:
                    result = function(**payload)
                except TypeError:
                    result = function(secret_object)

            return {
                "status": "ok",
                "message": f"Cliente agregado a MikroTik con {function_name}",
                "result": result,
            }

        except Exception as e:
            last_error = str(e)

    return {
        "status": "error",
        "message": (
            "No se pudo agregar a MikroTik. No se encontró una función compatible en mikrotik_service."
            if not last_error
            else f"No se pudo agregar a MikroTik: {last_direct_error or last_error}"
        ),
    }


