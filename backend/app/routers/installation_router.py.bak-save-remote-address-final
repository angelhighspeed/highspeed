@router.get("/installations/mikrotik-pools")
def get_installation_mikrotik_pools(
    router_id: int = Query(..., description="ID del router MikroTik seleccionado"),
    db: Session = Depends(get_db),
    current_user: dict = Depends(require_roles(["admin", "tecnico", "operador"])),
):
    """
    Lista los IP Pools reales del router seleccionado.
    Esto evita escribir manualmente el nombre del pool.
    """

    try:
        api, router = get_mikrotik_api_for_router(db, router_id)

        pool_resource = api.get_resource("/ip/pool")
        pools = pool_resource.get()

        result = []

        for pool in pools:
            name = pool.get("name")
            ranges_value = pool.get("ranges") or pool.get("range") or ""
            ranges = parse_pool_ranges(ranges_value)
            total_count = count_pool_ranges(ranges)

            if name:
                result.append({
                    "name": name,
                    "ranges": ranges_value,
                    "total_count": total_count,
                })

        return {
            "status": "ok",
            "router_id": router_id,
            "router_name": get_router_display_name(router),
            "pools": result,
        }

    except Exception as e:
        return {
            "status": "error",
            "router_id": router_id,
            "message": f"No se pudieron leer los pools del router: {str(e)}",
            "pools": [],
        }


@router.get("/installations/remote-address-pool/available")
def get_remote_address_pool_available(
    router_id: Optional[int] = Query(
        default=None,
        description="ID del router MikroTik seleccionado",
    ),
    pool_name: str = Query(
        default="Remote Address PPPoE",
        description="Nombre exacto del IP Pool en MikroTik",
    ),
    limit: int = Query(default=5000, ge=1, le=10000),
    only_active_clients: bool = Query(
        default=True,
        description="Si está activo, descarta IPs usadas por clientes activos/vigentes del CRM.",
    ),
    include_all_mikrotik_secrets: bool = Query(
        default=False,
        description="Si está activo, también descarta IPs de todos los PPP secrets habilitados.",
    ),
    db: Session = Depends(get_db),
    current_user: dict = Depends(require_roles(["admin", "tecnico", "operador"])),
):
    """
    Devuelve IPs libres del pool Remote Address PPPoE de MikroTik.
    También cruza contra las IPs ya guardadas en clientes locales.
    """

    clean_pool_name = str(pool_name or "Remote Address PPPoE").strip()

    ranges, warning, router, real_pool_name = get_mikrotik_pool_ranges(db, clean_pool_name, router_id)

    if not ranges:
        return {
            "status": "warning",
            "router_id": router_id,
            "router_name": get_router_display_name(router) if "router" in locals() and router else None,
            "pool_name": real_pool_name if "real_pool_name" in locals() else clean_pool_name,
            "message": warning or "No hay rangos configurados para el pool",
            "total_count": 0,
            "used_count": 0,
            "available_count": 0,
            "available_ips": [],
        }

    local_used = get_used_customer_remote_addresses(
        db,
        only_active_clients=only_active_clients,
    )

    pool_for_used_lookup = (
        real_pool_name if "real_pool_name" in locals() else clean_pool_name
    )

    mikrotik_used = get_used_mikrotik_addresses(
        db,
        pool_for_used_lookup,
        router_id,
        include_all_mikrotik_secrets=include_all_mikrotik_secrets,
    )

    used_ips = local_used.union(mikrotik_used)

    used_in_pool = {
        ip_value
        for ip_value in used_ips
        if ip_in_ranges(ip_value, ranges)
    }

    total_count = count_pool_ranges(ranges)
    available_count = max(total_count - len(used_in_pool), 0)

    available_ips = find_available_ips_from_ranges(
        ranges=ranges,
        used_ips=used_ips,
        limit=limit,
    )

    return {
        "status": "ok",
        "router_id": router_id,
        "router_name": get_router_display_name(router),
        "pool_name": real_pool_name if "real_pool_name" in locals() else clean_pool_name,
        "message": (
            "IPs libres obtenidas correctamente. "
            "Se excluyeron IPs con clientes activos/vigentes y PPPoE activos."
        ),
        "total_count": total_count,
        "used_count": len(used_in_pool),
        "local_used_count": len(local_used),
        "mikrotik_used_count": len(mikrotik_used),
        "available_count": available_count,
        "filter_mode": "clientes_activos_y_pppoe_activos",
        "include_all_mikrotik_secrets": include_all_mikrotik_secrets,
        "available_ips": available_ips,
    }


@router.get("/installations/available-ips")
def get_available_ips(
    prefix: str = Query(
        default="192.168.166",
        description="Prefijo de red. Ejemplo: 192.168.166",
    ),
    start: int = Query(default=2, ge=1, le=254),
    end: int = Query(default=254, ge=1, le=254),
    limit: int = Query(default=5000, ge=1, le=10000),
    db: Session = Depends(get_db),
    current_user: dict = Depends(require_roles(["admin", "tecnico", "operador"])),
):
    """
    Busca IPs disponibles usando las IPs ya cargadas en clientes.
    Ejemplo: prefix=192.168.166 devuelve 192.168.166.2, 192.168.166.3, etc.
    """

    clean_prefix = str(prefix or "").strip().rstrip(".")

    if not clean_prefix:
        raise HTTPException(status_code=400, detail="Prefijo inválido")

    if start > end:
        raise HTTPException(
            status_code=400,
            detail="El inicio del rango no puede ser mayor al final",
        )

    customers = db.query(Customer).all()

    used_ips = set()

    for customer in customers:
        ip = get_first_attr(
            customer,
            ["remote_address", "ip", "ip_address"],
        )

        if ip:
            used_ips.add(str(ip).strip())

    available_ips = []

    for host in range(start, end + 1):
        candidate_ip = f"{clean_prefix}.{host}"

        if candidate_ip not in used_ips:
            available_ips.append(candidate_ip)

        if len(available_ips) >= limit:
            break

    return {
        "status": "ok",
        "prefix": clean_prefix,
        "start": start,
        "end": end,
        "limit": limit,
        "used_count": len(used_ips),
        "available_count": len(available_ips),
        "available_ips": available_ips,
    }


