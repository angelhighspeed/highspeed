def normalize_ip_value(value):
    if value in [None, ""]:
        return None

    return str(value).strip()


def ip_to_int(ip_value):
    return int(IPv4Address(str(ip_value).strip()))


def int_to_ip(value):
    return str(IPv4Address(value))


def parse_pool_ranges(ranges_value):
    ranges = []

    if not ranges_value:
        return ranges

    for raw_part in str(ranges_value).split(","):
        part = raw_part.strip()

        if not part:
            continue

        if "-" in part:
            start_ip, end_ip = part.split("-", 1)
            ranges.append((start_ip.strip(), end_ip.strip()))
        else:
            ranges.append((part, part))

    return ranges


def count_pool_ranges(ranges):
    total = 0

    for start_ip, end_ip in ranges:
        try:
            total += ip_to_int(end_ip) - ip_to_int(start_ip) + 1
        except Exception:
            continue

    return total


def ip_in_ranges(ip_value, ranges):
    try:
        ip_number = ip_to_int(ip_value)
    except Exception:
        return False

    for start_ip, end_ip in ranges:
        try:
            if ip_to_int(start_ip) <= ip_number <= ip_to_int(end_ip):
                return True
        except Exception:
            continue

    return False


def is_customer_ip_blocking(customer: Customer):
    """
    Una IP queda ocupada si pertenece a un cliente activo/vigente.
    No bloquea clientes dados de baja, cancelados o eliminados.
    """

    status = get_first_attr(
        customer,
        [
            "status",
            "estado",
            "state",
        ],
        "",
    )

    status = str(status or "").strip().lower()

    inactive_statuses = {
        "inactive",
        "inactivo",
        "cancelled",
        "cancelado",
        "canceled",
        "deleted",
        "eliminado",
        "baja",
        "removed",
    }

    if status in inactive_statuses:
        return False

    # Si no tiene estado cargado, lo tomamos como vigente para evitar duplicar IP.
    return True


def get_used_customer_remote_addresses(db: Session, only_active_clients: bool = True):
    customers = db.query(Customer).all()

    used = set()

    for customer in customers:
        if only_active_clients and not is_customer_ip_blocking(customer):
            continue

        ip_value = get_first_attr(
            customer,
            ["remote_address", "ip", "ip_address"],
        )

        ip_value = normalize_ip_value(ip_value)

        if ip_value:
            used.add(ip_value)

    return used


def get_used_mikrotik_addresses(
    db: Session,
    pool_name: str,
    router_id: Optional[int] = None,
    include_all_mikrotik_secrets: bool = False,
):
    used = set()

    try:
        api, router = get_mikrotik_api_for_router(db, router_id)

        # IPs actualmente usadas por pools del MikroTik.
        try:
            used_resource = api.get_resource("/ip/pool/used")
            used_rows = used_resource.get()
        except Exception:
            used_rows = []

        for row in used_rows:
            row_pool = row.get("pool") or row.get("pool-name") or row.get("name")
            address = row.get("address") or row.get("active-address")

            if address and (not row_pool or str(row_pool).strip().lower() == str(pool_name).strip().lower()):
                used.add(str(address).strip())

        # PPPoE activos/conectados en MikroTik.
        try:
            active_resource = api.get_resource("/ppp/active")
            active_sessions = active_resource.get()
        except Exception:
            active_sessions = []

        for active in active_sessions:
            address = (
                active.get("address")
                or active.get("remote-address")
                or active.get("remote_address")
            )

            if address:
                used.add(str(address).strip())

        # Opcional: bloquear TODOS los secrets existentes.
        # Por defecto queda apagado para que el listado sea parecido a "clientes activos".
        if include_all_mikrotik_secrets:
            try:
                secret_resource = api.get_resource("/ppp/secret")
                secrets = secret_resource.get()
            except Exception:
                secrets = []

            for secret in secrets:
                disabled = str(secret.get("disabled", "false")).lower() in [
                    "true",
                    "yes",
                    "1",
                ]

                if disabled:
                    continue

                address = (
                    secret.get("remote-address")
                    or secret.get("remote_address")
                    or secret.get("address")
                )

                if address:
                    used.add(str(address).strip())

    except Exception:
        pass

    return used


def get_mikrotik_pool_ranges(db: Session, pool_name: str, router_id: Optional[int] = None):
    try:
        api, router = get_mikrotik_api_for_router(db, router_id)

        pool_resource = api.get_resource("/ip/pool")
        pools = pool_resource.get()

        requested = str(pool_name or "").strip()
        requested_lower = requested.lower()

        selected_pool = None

        for pool in pools:
            current_name = str(pool.get("name") or "").strip()

            if current_name.lower() == requested_lower:
                selected_pool = pool
                break

        # Fallback: if frontend guessed Pool-100M and MikroTik has pool-100M,
        # the case-insensitive check above handles it. This extra fallback catches
        # names like "PPPoE-100M" or "pool 100M".
        if not selected_pool:
            speed_match = re.search(r"(\d+)\s*m", requested_lower)

            if speed_match:
                speed = speed_match.group(1)

                for pool in pools:
                    current_name = str(pool.get("name") or "").strip().lower()

                    if speed + "m" in current_name:
                        selected_pool = pool
                        break

        if selected_pool:
            real_name = selected_pool.get("name")
            ranges_value = selected_pool.get("ranges") or selected_pool.get("range")
            return parse_pool_ranges(ranges_value), None, router, real_name

        available_names = ", ".join(
            str(pool.get("name") or "")
            for pool in pools
            if pool.get("name")
        )

        return (
            [],
            f"No se encontró el pool {pool_name}. Pools disponibles: {available_names}",
            router,
            requested,
        )

    except Exception as e:
        return [], f"No se pudo leer el pool de MikroTik: {str(e)}", None, pool_name


def find_available_ips_from_ranges(ranges, used_ips, limit):
    available = []

    for start_ip, end_ip in ranges:
        try:
            start_number = ip_to_int(start_ip)
            end_number = ip_to_int(end_ip)
        except Exception:
            continue

        for value in range(start_number, end_number + 1):
            candidate_ip = int_to_ip(value)

            if candidate_ip not in used_ips:
                available.append(candidate_ip)

            if len(available) >= limit:
                return available

    return available






