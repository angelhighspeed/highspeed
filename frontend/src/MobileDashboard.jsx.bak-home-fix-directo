function SmallMetric({ icon, value, label, trend, color = "#0ea5e9" }) {
  return (
    <div className="hsm-metric-mini">
      <div className="hsm-metric-icon" style={{ background: `${color}16` }}>
        <span>{icon}</span>
      </div>
      <div>
        <strong>{value}</strong>
        <p>{label}</p>
        {trend ? <small style={{ color }}>{trend}</small> : null}
