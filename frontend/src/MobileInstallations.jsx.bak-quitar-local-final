    phone: form.phone,
    telefono: form.phone,
    address: form.address,
    direccion: form.address,
    city: form.city,
    localidad: form.city,
    zone: form.zone,
    zona: form.zone,
    date: form.date,
    fecha: form.date,
    notes: form.notes,
    observaciones: form.notes,
    status: "pending",
    estado: "Pendiente",
    completed: false,
    is_completed: false,
    created_at: new Date().toISOString(),
  };
}

function MobileInstallations() {
  const [installations, setInstallations] = useState([]);
  const [clients, setClients] = useState([]);
  const [plans, setPlans] = useState([]);
  const [routers, setRouters] = useState([]);

  const [query, setQuery] = useState("");
  const [filter, setFilter] = useState("pendientes");
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");

  const [showCreate, setShowCreate] = useState(false);
  const [createForm, setCreateForm] = useState(emptyCreateForm);
  const [selectedInstallation, setSelectedInstallation] = useState(null);
  const [completeForm, setCompleteForm] = useState(emptyCompleteForm);
  const [ipRanges, setIpRanges] = useState([]);
  const [availableIps, setAvailableIps] = useState([]);
  const [saving, setSaving] = useState(false);

  const loadInstallations = async () => {
    try {
      setLoading(true);
      setError("");

      let res;

      const attempts = [
        `${API}/installations`,
        `${API}/instalaciones`,
        `${API}/installation`,
        `${API}/customers/installations`,
      ];

      for (const url of attempts) {
        try {
          res = await axios.get(url, getHeaders());
          break;
        } catch (err) {
          console.warn("Intento instalaciones falló:", url, err?.response?.status || err?.message);
        }
      }

      const data = Array.isArray(res?.data)
        ? res.data
        : Array.isArray(res?.data?.items)
        ? res.data.items
        : Array.isArray(res?.data?.installations)
        ? res.data.installations
        : Array.isArray(res?.data?.instalaciones)
        ? res.data.instalaciones
        : [];

      const localData = getLocalInstallations();

      const merged = [
        ...data,
        ...localData.filter((localItem) => {
          return !data.some((backendItem) => String(backendItem.id) === String(localItem.id));
        }),
      ];

      setInstallations(merged);
    } catch (err) {
      console.error(err);
      setError("No se pudieron cargar las instalaciones.");
    } finally {
      setLoading(false);
    }
  };

  const loadOptions = async () => {
    try {
      const [clientsRes, plansRes, routersRes] = await Promise.all([
        axios.get(`${API}/customers`, getHeaders()).catch(() => axios.get(`${API}/customers/list-all`, getHeaders()).catch(() => ({ data: [] }))),
        axios.get(`${API}/plans`, getHeaders()).catch(() => ({ data: [] })),
        axios.get(`${API}/routers`, getHeaders()).catch(() => ({ data: [] })),
      ]);

      const clientsData = Array.isArray(clientsRes.data)
        ? clientsRes.data
        : Array.isArray(clientsRes.data?.items)
        ? clientsRes.data.items
        : Array.isArray(clientsRes.data?.customers)
        ? clientsRes.data.customers
        : [];

      const plansData = Array.isArray(plansRes.data)
        ? plansRes.data
        : Array.isArray(plansRes.data?.items)
        ? plansRes.data.items
        : Array.isArray(plansRes.data?.plans)
        ? plansRes.data.plans
        : [];

      const routersData = Array.isArray(routersRes.data)
        ? routersRes.data
        : Array.isArray(routersRes.data?.items)
        ? routersRes.data.items
        : Array.isArray(routersRes.data?.routers)
        ? routersRes.data.routers
        : [];

      setClients(clientsData);
      setPlans(plansData);
      setRouters(routersData);
    } catch (err) {
      console.warn("No se pudieron cargar opciones:", err);
    }
  };

  useEffect(() => {
    loadInstallations();
    loadOptions();
  }, []);

  const stats = useMemo(() => {
    let pendientes = 0;
    let proceso = 0;
    let completadas = 0;

    installations.forEach((item) => {
      const status = getStatus(item).toLowerCase();

      if (status.includes("complet")) completadas += 1;
      else if (status.includes("proceso")) proceso += 1;
      else pendientes += 1;
    });

    return {
      total: installations.length,
      pendientes,
      proceso,
      completadas,
    };
  }, [installations]);

  const filteredInstallations = useMemo(() => {
    const q = query.trim().toLowerCase();

    return installations.filter((item) => {
      const status = getStatus(item).toLowerCase();

      if (filter === "pendientes" && isCompleted(item)) return false;
      if (filter === "completadas" && !isCompleted(item)) return false;

      const text = [
        getClientName(item),
        getPhone(item),
        getAddress(item),
        item.notes,
        item.observaciones,
        item.zone,
        item.zona,
        status,
      ]
        .join(" ")
        .toLowerCase();

      return !q || text.includes(q);
    });
  }, [installations, query, filter]);

  const updateCreateForm = (field, value) => {
    setCreateForm((prev) => ({ ...prev, [field]: value }));
  };

  const updateCompleteForm = (field, value) => {
    setCompleteForm((prev) => ({ ...prev, [field]: value }));
  };

  const createInstallation = async (e) => {
    e.preventDefault();

    if (!createForm.name.trim()) {
      alert("Ingresá el nombre del cliente.");
      return;
    }

    if (!createForm.phone.trim()) {
      alert("Ingresá el teléfono.");
      return;
    }

    if (!createForm.address.trim()) {
      alert("Ingresá la dirección.");
      return;
    }

    try {
      setSaving(true);

      const payload = {
        ...createForm,
        customer_name: createForm.name,
        client_name: createForm.name,
        nombre: createForm.name,
        telefono: createForm.phone,
        phone: createForm.phone,
        direccion: createForm.address,
        address: createForm.address,
        localidad: createForm.city,
        zona: createForm.zone,
        fecha: createForm.date,
        status: "pending",
        estado: "Pendiente",
        notes: createForm.notes,
        observaciones: createForm.notes,
      };

      let saved = false;

      const attempts = [
        () => axios.post(`${API}/installations`, payload, getHeaders()),
        () => axios.post(`${API}/instalaciones`, payload, getHeaders()),
        () => axios.post(`${API}/installation`, payload, getHeaders()),
        () => axios.post(`${API}/customers/installations`, payload, getHeaders()),
      ];

      for (const attempt of attempts) {
        try {
          await attempt();
          saved = true;
          break;
        } catch (err) {
          console.warn("Intento crear instalación falló:", err?.response?.status || err?.message);
        }
      }

      if (!saved) {
        alert("No se pudo crear la instalación en el servidor. Para sincronizar con la web, hace falta el endpoint de instalaciones en el backend.");
        return;
      }

      setCreateForm(emptyCreateForm);
      setShowCreate(false);
      setFilter("pendientes");
      await loadInstallations();

      alert("Instalación creada como pendiente.");
    } finally {
      setSaving(false);
    }
  };

  const openComplete = (installation) => {
    const defaultUser =
      installation.pppoe_user ||
      installation.username ||
      buildPppoeUser(installation);

    setSelectedInstallation(installation);
    setCompleteForm({
      ...emptyCompleteForm,
      pppoe_user: defaultUser,
      pppoe_password: installation.pppoe_password || defaultUser,
    });
    setIpRanges([]);
    setAvailableIps([]);
  };

  const closeComplete = () => {
    setSelectedInstallation(null);
    setCompleteForm(emptyCompleteForm);
    setIpRanges([]);
    setAvailableIps([]);
  };

  const loadRouterRangesFromLocal = (routerId) => {
    if (!routerId) {
      setIpRanges([]);
      setAvailableIps([]);
      return;
    }

    const router = routers.find((item) => String(item.id) === String(routerId));

    if (!router) {
      setIpRanges([]);
      setAvailableIps([]);
      return;
    }

    const ranges = getRouterRanges(router).map((range, index) => ({
      id: range,
      name: range,
      range,
      cidr: range,
      index,
    }));

    setIpRanges(ranges);
    setAvailableIps([]);
  };

  const loadAvailableIpsFromRange = (rangeValue) => {
    if (!rangeValue) {
      setAvailableIps([]);
      return;
    }

    const selected = ipRanges.find((range) =>
      String(range.id || range.range || range.cidr || range.name) === String(rangeValue)
    );

    const rangeText =
      selected?.range ||
      selected?.cidr ||
      selected?.name ||
      String(rangeValue);

    const usedIps = new Set(
      clients
        .map((client) => String(getClientIp(client)).trim())
        .filter(Boolean)
    );

    const ips = expandIpRange(rangeText)
      .filter((ip) => !usedIps.has(ip))
      .map((ip) => ({
        id: ip,
        ip,
      }));

    setAvailableIps(ips);
  };

  const createActiveCustomer = async (installation, form) => {
    const payload = {
      name: installation.name || installation.nombre || installation.customer_name || getClientName(installation),
      nombre: installation.name || installation.nombre || installation.customer_name || getClientName(installation),
      full_name: getClientName(installation),
      phone: getPhone(installation),
      telefono: getPhone(installation),
      email: installation.email || "",
      address: getAddress(installation),
      direccion: getAddress(installation),
      city: installation.city || installation.localidad || "",
      zone: installation.zone || installation.zona || "",
      plan_id: form.plan_id ? Number(form.plan_id) : null,
      router_id: form.router_id ? Number(form.router_id) : null,
      ip: form.ip,
      ip_address: form.ip,
      pppoe_ip: form.ip,
      username: form.pppoe_user,
      pppoe_user: form.pppoe_user,
      user: form.pppoe_user,
      password: form.pppoe_password,
      pppoe_password: form.pppoe_password,
      status: "active",
      estado: "Activo",
      active: true,
      installation_id: installation.id,
      notes: form.comment,
      observaciones: form.comment,
    };

    const attempts = [
      () => axios.post(`${API}/customers`, payload, getHeaders()),
      () => axios.post(`${API}/customers/`, payload, getHeaders()),
      () => axios.post(`${API}/clients`, payload, getHeaders()),
    ];

    for (const attempt of attempts) {
      try {
        const res = await attempt();
        return res.data;
      } catch (err) {
        console.warn("Intento crear cliente desde instalación falló:", err?.response?.status || err?.message);
      }
    }

    throw new Error("No se pudo crear el cliente activo.");
  };

  const addToMikrotik = async (customerData, installation, form) => {
    const payload = {
      customer_id: customerData?.id || customerData?.customer?.id || installation.customer_id || null,
      installation_id: installation.id,
      router_id: Number(form.router_id),
      plan_id: Number(form.plan_id),
      username: form.pppoe_user,
      pppoe_user: form.pppoe_user,
      password: form.pppoe_password,
      pppoe_password: form.pppoe_password,
      ip: form.ip,
      ip_address: form.ip,
      comment: form.comment || getClientName(installation),
      name: getClientName(installation),
    };

    const attempts = [
      () => axios.post(`${API}/mikrotik/pppoe/add`, payload, getHeaders()),
      () => axios.post(`${API}/mikrotik/pppoe/create`, payload, getHeaders()),
      () => axios.post(`${API}/pppoe/add`, payload, getHeaders()),
      () => axios.post(`${API}/routers/${form.router_id}/pppoe/add`, payload, getHeaders()),
      () => axios.post(`${API}/customers/${payload.customer_id}/mikrotik/add`, payload, getHeaders()),
    ];

    for (const attempt of attempts) {
      try {
        await attempt();
        return true;
      } catch (err) {
        console.warn("Intento agregar PPPoE MikroTik falló:", err?.response?.status || err?.message);
      }
    }

    return false;
  };

  const markInstallationCompleted = async (installation, customerData, mikrotikAdded) => {
    const id = installation.id;

    if (!id) return false;

    if (installation.local_only) {
      const localItems = getLocalInstallations();

      const updated = localItems.map((item) =>
        item.id === id
          ? {
              ...item,
              status: "completed",
              estado: "Completada",
              completed: true,
              is_completed: true,
              completed_at: new Date().toISOString(),
              customer_id: customerData?.id || customerData?.customer?.id || null,
              mikrotik_added: mikrotikAdded,
            }
          : item
      );

      setLocalInstallations(updated);
      return true;
    }

    const payload = {
      status: "completed",
      estado: "Completada",
      completed: true,
      is_completed: true,
      completed_at: new Date().toISOString(),
      customer_id: customerData?.id || customerData?.customer?.id || installation.customer_id || null,
      mikrotik_added: mikrotikAdded,
    };

    const attempts = [
      () => axios.patch(`${API}/installations/${id}`, payload, getHeaders()),
      () => axios.put(`${API}/installations/${id}`, payload, getHeaders()),
      () => axios.post(`${API}/installations/${id}/complete`, payload, getHeaders()),
      () => axios.patch(`${API}/instalaciones/${id}`, payload, getHeaders()),
      () => axios.post(`${API}/instalaciones/${id}/complete`, payload, getHeaders()),
    ];

    for (const attempt of attempts) {
      try {
        await attempt();
        return true;
      } catch (err) {
        console.warn("Intento marcar instalación completada falló:", err?.response?.status || err?.message);
      }
    }

    return false;
  };

  const completeInstallation = async (e) => {
    e.preventDefault();

    if (!selectedInstallation) return;

    if (!completeForm.plan_id) {
      alert("Seleccioná un plan.");
      return;
    }

    if (!completeForm.router_id) {
      alert("Seleccioná un router.");
      return;
    }

    if (!completeForm.ip) {
      alert("Seleccioná una IP disponible.");
      return;
    }

    if (!completeForm.pppoe_user.trim()) {
      alert("Ingresá el usuario PPPoE.");
      return;
    }

    if (!completeForm.pppoe_password.trim()) {
      alert("Ingresá la contraseña PPPoE.");
      return;
    }

    const ok = confirm(
      "¿Completar instalación, crear cliente activo y agregar al MikroTik?"
    );

    if (!ok) return;

    try {
      setSaving(true);

      const customerData = await createActiveCustomer(selectedInstallation, completeForm);
      const mikrotikAdded = await addToMikrotik(customerData, selectedInstallation, completeForm);
      const completed = await markInstallationCompleted(selectedInstallation, customerData, mikrotikAdded);

      if (selectedInstallation.local_only) {
        const localItems = getLocalInstallations();
        setLocalInstallations(
          localItems.map((item) =>
            item.id === selectedInstallation.id
              ? {
                  ...item,
                  status: "completed",
                  estado: "Completada",
                  completed: true,
                  is_completed: true,
                  completed_at: new Date().toISOString(),
                }
              : item
          )
        );
      }

      setInstallations((prev) =>
        prev.filter((item) => item.id !== selectedInstallation.id)
      );

      closeComplete();
      await loadOptions();
      await loadInstallations();

      if (mikrotikAdded && completed) {
        alert("Instalación completada. Cliente activo creado y agregado al MikroTik.");
      } else if (!mikrotikAdded && completed) {
        alert("Cliente activo creado y la instalación fue completada. No se encontró endpoint para agregar al MikroTik.");
      } else {
        alert("Cliente activo creado. No se pudo marcar la instalación como completada en backend, pero se ocultó en la APK.");
      }
    } catch (err) {
      console.error(err);
      alert("No se pudo completar la instalación. Revisá datos, endpoint de clientes o MikroTik.");
    } finally {
      setSaving(false);
    }
  };

  return (
    <div className="hsm-install-page">
      <section className="hsm-install-head">
        <div>
          <h2>Instalaciones</h2>
          <p>{stats.pendientes} pendientes · {stats.completadas} completadas</p>
        </div>

        <div className="hsm-install-head-actions">
          <button onClick={() => setShowCreate(true)}>+ Nueva</button>
          <button onClick={() => { loadInstallations(); loadOptions(); }}>
            Actualizar
          </button>
        </div>
      </section>

      <section className="hsm-install-stats">
        <div>
          <strong>{stats.pendientes}</strong>
          <span>Pendientes</span>
        </div>

        <div>
          <strong>{stats.proceso}</strong>
          <span>En proceso</span>
        </div>

        <div>
          <strong>{stats.completadas}</strong>
          <span>Completadas</span>
        </div>
      </section>

      <section className="hsm-install-search">
        <input
          value={query}
          onChange={(e) => setQuery(e.target.value)}
          placeholder="Buscar instalación, cliente, teléfono o dirección..."
        />

        <div className="hsm-install-filter">
          <button
            className={filter === "pendientes" ? "active" : ""}
            onClick={() => setFilter("pendientes")}
          >
            Pendientes
          </button>

          <button
            className={filter === "todas" ? "active" : ""}
            onClick={() => setFilter("todas")}
          >
            Todas
          </button>

          <button
            className={filter === "completadas" ? "active" : ""}
            onClick={() => setFilter("completadas")}
          >
            Completadas
          </button>
        </div>
      </section>

      {showCreate && (
        <section className="hsm-install-complete-card">
          <div className="hsm-install-form-head">
            <h3>Nueva instalación</h3>
            <button onClick={() => setShowCreate(false)}>×</button>
          </div>

          <form onSubmit={createInstallation} className="hsm-install-form">
            <input
              placeholder="Nombre del cliente"
              value={createForm.name}
              onChange={(e) => updateCreateForm("name", e.target.value)}
            />

            <input
              placeholder="Teléfono"
              value={createForm.phone}
              onChange={(e) => updateCreateForm("phone", e.target.value)}
            />

            <input
              placeholder="Dirección"
              value={createForm.address}
              onChange={(e) => updateCreateForm("address", e.target.value)}
            />

            <input
              placeholder="Localidad"
              value={createForm.city}
              onChange={(e) => updateCreateForm("city", e.target.value)}
            />

            <input
              placeholder="Zona / Barrio"
              value={createForm.zone}
              onChange={(e) => updateCreateForm("zone", e.target.value)}
            />

            <input
              type="date"
              value={createForm.date}
              onChange={(e) => updateCreateForm("date", e.target.value)}
            />

            <textarea
              placeholder="Notas de instalación"
              value={createForm.notes}
              onChange={(e) => updateCreateForm("notes", e.target.value)}
            />

            <button type="submit" disabled={saving}>
              {saving ? "Guardando..." : "Crear instalación pendiente"}
            </button>
          </form>
        </section>
      )}

      {selectedInstallation && (
        <section className="hsm-install-complete-card">
          <div className="hsm-install-form-head">
            <h3>Completar instalación</h3>
            <button onClick={closeComplete}>×</button>
          </div>

          <div className="hsm-install-selected">
            <b>{getClientName(selectedInstallation)}</b>
            <span>{getAddress(selectedInstallation)}</span>
          </div>

          <form onSubmit={completeInstallation} className="hsm-install-form">
            <select
              value={completeForm.plan_id}
              onChange={(e) => updateCompleteForm("plan_id", e.target.value)}
            >
              <option value="">Seleccionar plan</option>
              {plans.map((plan) => (
                <option key={plan.id} value={plan.id}>
                  {getPlanLabel(plan)}
                </option>
              ))}
            </select>

            <select
              value={completeForm.router_id}
              onChange={(e) => {
                updateCompleteForm("router_id", e.target.value);
                updateCompleteForm("ip_range", "");
                updateCompleteForm("ip", "");
                loadRouterRangesFromLocal(e.target.value);
              }}
            >
              <option value="">Seleccionar router</option>
              {routers.map((router) => (
                <option key={router.id} value={router.id}>
                  {getRouterLabel(router)}
                </option>
              ))}
            </select>

            <select
              value={completeForm.ip_range}
              onChange={(e) => {
                updateCompleteForm("ip_range", e.target.value);
                updateCompleteForm("ip", "");
                loadAvailableIpsFromRange(e.target.value);
              }}
            >
              <option value="">Seleccionar rango IP</option>
              {ipRanges.map((range) => (
                <option key={range.id} value={range.id}>
                  {range.name}
                </option>
              ))}
            </select>

            <select
              value={completeForm.ip}
              onChange={(e) => updateCompleteForm("ip", e.target.value)}
            >
              <option value="">Seleccionar IP disponible</option>
              {availableIps.map((item) => (
                <option key={item.ip} value={item.ip}>
                  {item.ip}
                </option>
              ))}
            </select>

            <input
              placeholder="IP manual si no aparece"
              value={completeForm.ip}
              onChange={(e) => updateCompleteForm("ip", e.target.value)}
            />

            <input
              placeholder="Usuario PPPoE"
              value={completeForm.pppoe_user}
              onChange={(e) => updateCompleteForm("pppoe_user", e.target.value)}
            />

            <input
              placeholder="Contraseña PPPoE"
              value={completeForm.pppoe_password}
              onChange={(e) => updateCompleteForm("pppoe_password", e.target.value)}
            />

            <textarea
              placeholder="Comentario de instalación"
              value={completeForm.comment}
              onChange={(e) => updateCompleteForm("comment", e.target.value)}
            />

            <button type="submit" disabled={saving}>
              {saving ? "Completando..." : "Completar, crear cliente y agregar MikroTik"}
            </button>
          </form>
        </section>
      )}

      {loading && (
        <div className="hsm-card">
          <p>Cargando instalaciones...</p>
        </div>
      )}

      {error && (
        <div className="hsm-card">
          <p style={{ color: "#dc2626", fontWeight: 800 }}>{error}</p>
        </div>
      )}

      {!loading && !error && filteredInstallations.length === 0 && (
        <div className="hsm-card">
          <p>No hay instalaciones para mostrar.</p>
        </div>
      )}

      <section className="hsm-install-list">
        {filteredInstallations.map((item) => {
          const status = getStatus(item);
          const phone = getPhone(item);
          const cleanPhone = String(phone).replace(/\D/g, "");

          return (
            <article key={item.id || `${getClientName(item)}-${getAddress(item)}`} className="hsm-install-card">
              <div className="hsm-install-top">
                <div className="hsm-install-icon">🛠️</div>

                <div className="hsm-install-main">
                  <h3>{getClientName(item)}</h3>
                  <span>{status}</span>
                </div>
              </div>

              <div className="hsm-install-info">
                <div>
                  <b>Dirección</b>
                  <span>{getAddress(item)}</span>
                </div>

                <div>
                  <b>Teléfono</b>
                  <span>{phone || "-"}</span>
                </div>

                <div>
                  <b>Fecha</b>
                  <span>{item.date || item.fecha || item.created_at || "-"}</span>
                </div>

                <div>
                  <b>Zona</b>
                  <span>{item.zone || item.zona || "-"}</span>
                </div>
              </div>

              <div className="hsm-install-actions">
                {cleanPhone ? (
                  <a href={`https://wa.me/${cleanPhone}`} target="_blank" rel="noreferrer">
                    WhatsApp
                  </a>
                ) : null}

                {!isCompleted(item) && (
                  <button onClick={() => openComplete(item)}>
                    Completar
                  </button>
                )}
              </div>
            </article>
          );
        })}
      </section>
    </div>
  );
}

export default MobileInstallations;
