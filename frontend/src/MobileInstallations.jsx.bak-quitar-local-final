function getClientName(item) {
  const first =
    item.name ||
    item.nombre ||
    item.customer_name ||
    item.client_name ||
    item.first_name ||
    "";

  const last =
    item.last_name ||
    item.apellido ||
    "";

  return (
    item.full_name ||
    item.nombre_completo ||
    `${first} ${last}`.trim() ||
    `Cliente #${item.customer_id || item.id || "-"}`
  );
}

function getPhone(item) {
  return (
    item.phone ||
    item.telefono ||
    item.mobile ||
    item.celular ||
    item.whatsapp ||
    ""
  );
}

function getAddress(item) {
  return (
    item.address ||
    item.direccion ||
    item.installation_address ||
    item.customer_address ||
    "Sin dirección"
  );
}

function getStatus(item) {
  const raw = String(item.status || item.estado || "").toLowerCase();

  if (raw.includes("complete") || raw.includes("complet")) return "Completada";
  if (raw.includes("cancel")) return "Cancelada";
  if (raw.includes("pending") || raw.includes("pendiente")) return "Pendiente";
  if (raw.includes("progress") || raw.includes("proceso")) return "En proceso";

  return raw ? raw : "Pendiente";
}

function isCompleted(item) {
  const status = getStatus(item).toLowerCase();

  return (
    status.includes("complet") ||
    status.includes("cancel") ||
    item.completed === true ||
    item.is_completed === true
  );
}

function getPlanLabel(plan) {
  return (
    plan.name ||
    plan.nombre ||
    plan.plan_name ||
    plan.nombre_plan ||
    `Plan #${plan.id}`
  );
}

function getRouterLabel(router) {
  const name = router.name || router.nombre || router.router_name || `Router #${router.id}`;
  const ip = router.host || router.ip || router.ip_address || router.address || "";
  return ip ? `${name} - ${ip}` : name;
}

function getRouterRanges(router) {
  const raw =
    router.ip_ranges ||
    router.rangos_ip ||
    router.ranges ||
    router.ip_pools ||
    router.pools ||
    "";

  if (Array.isArray(raw)) {
    return raw
      .map((item) => {
        if (typeof item === "string") return item;
        return item.cidr || item.range || item.network || item.pool || item.name || "";
      })
      .filter(Boolean);
  }

  return String(raw || "")
    .split(/\n|,/)
    .map((line) => line.trim())
    .filter(Boolean);
}

function ipToNum(ip) {
  const parts = String(ip).trim().split(".").map(Number);
  if (parts.length !== 4 || parts.some((n) => Number.isNaN(n) || n < 0 || n > 255)) return null;
  return ((parts[0] << 24) >>> 0) + (parts[1] << 16) + (parts[2] << 8) + parts[3];
}

function numToIp(num) {
  return [
    (num >>> 24) & 255,
    (num >>> 16) & 255,
    (num >>> 8) & 255,
    num & 255,
  ].join(".");
}

function expandCidr(cidr) {
  const [ip, prefixRaw] = String(cidr).trim().split("/");
  const prefix = Number(prefixRaw);

  const base = ipToNum(ip);
  if (base === null || Number.isNaN(prefix) || prefix < 0 || prefix > 32) return [];

  const mask = prefix === 0 ? 0 : (0xffffffff << (32 - prefix)) >>> 0;
  const network = base & mask;
  const broadcast = network + (2 ** (32 - prefix)) - 1;

  const start = prefix >= 31 ? network : network + 1;
  const end = prefix >= 31 ? broadcast : broadcast - 1;

  const ips = [];
  const limit = 512;

  for (let n = start; n <= end && ips.length < limit; n++) {
    ips.push(numToIp(n >>> 0));
  }

  return ips;
}

function expandIpRange(rangeText) {
  const text = String(rangeText || "").trim();

  if (!text) return [];

  if (text.includes("/")) return expandCidr(text);

  if (text.includes("-")) {
    const [startRaw, endRaw] = text.split("-").map((x) => x.trim());
    const start = ipToNum(startRaw);
    const end = ipToNum(endRaw);

    if (start === null || end === null || end < start) return [];

    const ips = [];
    const limit = 512;

    for (let n = start; n <= end && ips.length < limit; n++) {
      ips.push(numToIp(n >>> 0));
    }

    return ips;
  }

  return ipToNum(text) === null ? [] : [text];
}

function getClientIp(client) {
  return (
    client.ip ||
    client.ip_address ||
    client.pppoe_ip ||
    client.router_ip ||
    client.address_ip ||
    ""
  );
}

function buildPppoeUser(item) {
  const base = getClientName(item)
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "")
    .slice(0, 18);

  return base || `cliente${item.id || Date.now()}`;
}


function getLocalInstallations() {
  return [];
}

function setLocalInstallations(items) {
  return;
}

function makeLocalInstallation(form) {
  return {
    id: `local-${Date.now()}`,
    local_only: true,
    name: form.name,
    nombre: form.name,
