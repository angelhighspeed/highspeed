import { useEffect, useMemo, useState } from "react";
import axios from "axios";

const API = import.meta.env.VITE_API_URL || "http://192.168.0.113:8000";

function getToken() {
  return localStorage.getItem("token") || localStorage.getItem("access_token") || "";
}

function getHeaders() {
  return {
    headers: {
      Authorization: `Bearer ${getToken()}`,
    },
  };
}

const emptyForm = {
  id: null,
  name: "",
  last_name: "",
  dni: "",
  phone: "",
  email: "",
  address: "",
  city: "",
  zone: "",
  plan_id: "",
  router_id: "",
  ip_range: "",
  pppoe_user: "",
  pppoe_password: "",
  ip: "",
  status: "Activo",
  notes: "",
};

function getFullName(client) {
  const first =
    client.name ||
    client.nombre ||
    client.first_name ||
    client.firstname ||
    "";

  const last =
    client.last_name ||
    client.apellido ||
    client.lastname ||
    "";

  const full = `${first} ${last}`.trim();

  return (
    client.full_name ||
    client.nombre_completo ||
    client.customer_name ||
    full ||
    `Cliente #${client.id}`
  );
}

function getPhone(client) {
  return (
    client.phone ||
    client.telefono ||
    client.mobile ||
    client.celular ||
    client.whatsapp ||
    ""
  );
}

function getStatus(client) {
  const raw = String(
    client.status ||
      client.estado ||
      client.state ||
      ""
  ).toLowerCase();

  if (raw.includes("suspend")) return "Suspendido";
  if (raw.includes("cort")) return "Cortado";
  if (raw.includes("activo") || raw.includes("active")) return "Activo";
  if (raw.includes("pending") || raw.includes("pendiente")) return "Pendiente";

  return raw ? raw : "Sin estado";
}

function statusClass(status) {
  const s = status.toLowerCase();

  if (s.includes("activo")) return "ok";
  if (s.includes("suspendido") || s.includes("cortado")) return "bad";
  if (s.includes("pendiente")) return "warn";

  return "";
}

function clientToForm(client) {
  return {
    id: client.id || null,
    name: client.name || client.nombre || client.first_name || "",
    last_name: client.last_name || client.apellido || "",
    dni: client.dni || client.document || client.documento || "",
    phone: getPhone(client),
    email: client.email || "",
    address: client.address || client.direccion || "",
    city: client.city || client.localidad || "",
    zone: client.zone || client.zona || client.barrio || "",
    plan_id: client.plan_id || "",
    router_id: client.router_id || "",
    pppoe_user: client.pppoe_user || client.username || client.user || "",
    pppoe_password: client.pppoe_password || client.password || "",
    ip: client.ip || client.ip_address || client.pppoe_ip || "",
    status: getStatus(client),
    notes: client.notes || client.observaciones || client.comments || "",
  };
}


function getPlanLabel(plan) {
  return (
    plan.name ||
    plan.nombre ||
    plan.plan_name ||
    `Plan #${plan.id}`
  );
}

function getRouterLabel(router) {
  const name = router.name || router.nombre || router.router_name || `Router #${router.id}`;
  const ip = router.host || router.ip || router.ip_address || router.address || "";
  return ip ? `${name} - ${ip}` : name;
}

function getIpRangeLabel(range) {
  return (
    range.name ||
    range.nombre ||
    range.range ||
    range.cidr ||
    range.network ||
    range.pool ||
    range.subnet ||
    `Rango #${range.id}`
  );
}

function MobileClients() {
  const [clients, setClients] = useState([]);
  const [plans, setPlans] = useState([]);
  const [routers, setRouters] = useState([]);
  const [ipRanges, setIpRanges] = useState([]);
  const [query, setQuery] = useState("");
  const [statusFilter, setStatusFilter] = useState("todos");
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");

  const [showForm, setShowForm] = useState(false);
  const [saving, setSaving] = useState(false);
  const [form, setForm] = useState(emptyForm);
  const [changingId, setChangingId] = useState(null);
  const [expandedId, setExpandedId] = useState(null);

  const loadClients = async () => {
    try {
      setLoading(true);
      setError("");

      let res;

      try {
        res = await axios.get(`${API}/customers`, getHeaders());
      } catch {
        res = await axios.get(`${API}/customers/list-all`, getHeaders());
      }

      const data = Array.isArray(res.data)
        ? res.data
        : Array.isArray(res.data?.items)
        ? res.data.items
        : Array.isArray(res.data?.customers)
        ? res.data.customers
        : [];

      setClients(data);
    } catch (err) {
      console.error(err);
      setError("No se pudieron cargar los clientes.");
    } finally {
      setLoading(false);
    }
  };


  const loadClientOptions = async () => {
    try {
      const [plansRes, routersRes] = await Promise.all([
        axios.get(`${API}/plans`, getHeaders()).catch(() => ({ data: [] })),
        axios.get(`${API}/routers`, getHeaders()).catch(() => ({ data: [] })),
      ]);

      const plansData = Array.isArray(plansRes.data)
        ? plansRes.data
        : Array.isArray(plansRes.data?.items)
        ? plansRes.data.items
        : Array.isArray(plansRes.data?.plans)
        ? plansRes.data.plans
        : [];

      const routersData = Array.isArray(routersRes.data)
        ? routersRes.data
        : Array.isArray(routersRes.data?.items)
        ? routersRes.data.items
        : Array.isArray(routersRes.data?.routers)
        ? routersRes.data.routers
        : [];

      setPlans(plansData);
      setRouters(routersData);
    } catch (err) {
      console.warn("No se pudieron cargar planes/routers:", err);
    }
  };

  const loadIpRanges = async (routerId) => {
    if (!routerId) {
      setIpRanges([]);
      return;
    }

    const attempts = [
      `${API}/routers/${routerId}/ip-ranges`,
      `${API}/routers/${routerId}/ip-pools`,
      `${API}/routers/${routerId}/available-ips`,
      `${API}/ip-ranges?router_id=${routerId}`,
      `${API}/ip-pools?router_id=${routerId}`,
    ];

    for (const url of attempts) {
      try {
        const res = await axios.get(url, getHeaders());

        const data = Array.isArray(res.data)
          ? res.data
          : Array.isArray(res.data?.items)
          ? res.data.items
          : Array.isArray(res.data?.ranges)
          ? res.data.ranges
          : Array.isArray(res.data?.pools)
          ? res.data.pools
          : Array.isArray(res.data?.available_ips)
          ? res.data.available_ips
          : [];

        setIpRanges(data);
        return;
      } catch (err) {
        console.warn("Intento cargar rangos IP falló:", url, err?.response?.status || err?.message);
      }
    }

    setIpRanges([]);
  };

  useEffect(() => {
    loadClients();
    loadClientOptions();
  }, []);

  const stats = useMemo(() => {
    let activos = 0;
    let suspendidos = 0;
    let pendientes = 0;

    clients.forEach((client) => {
      const status = getStatus(client).toLowerCase();

      if (status.includes("activo")) activos += 1;
      else if (status.includes("suspendido") || status.includes("cortado")) suspendidos += 1;
      else pendientes += 1;
    });

    return {
      total: clients.length,
      activos,
      suspendidos,
      pendientes,
    };
  }, [clients]);

  const filteredClients = useMemo(() => {
    const q = query.trim().toLowerCase();

    return clients.filter((client) => {
      const name = getFullName(client).toLowerCase();
      const phone = getPhone(client).toLowerCase();
      const address = String(
        client.address ||
          client.direccion ||
          client.location ||
          client.ubicacion ||
          ""
      ).toLowerCase();

      const status = getStatus(client).toLowerCase();

      const matchText =
        !q ||
        name.includes(q) ||
        phone.includes(q) ||
        address.includes(q);

      const matchStatus =
        statusFilter === "todos" ||
        status.includes(statusFilter);

      return matchText && matchStatus;
    });
  }, [clients, query, statusFilter]);

  const updateForm = (field, value) => {
    setForm((prev) => ({ ...prev, [field]: value }));
  };

  const openNewClient = () => {
    setForm(emptyForm);
    setShowForm(true);
  };

  const openEditClient = (client) => {
    const nextForm = clientToForm(client);
    setForm(nextForm);
    setShowForm(true);

    if (nextForm.router_id) {
      loadIpRanges(nextForm.router_id);
    }
  };

  const saveClient = async (e) => {
    e.preventDefault();

    if (!form.name.trim()) {
      alert("Ingresá el nombre del cliente.");
      return;
    }

    if (!form.phone.trim()) {
      alert("Ingresá el teléfono.");
      return;
    }

    if (!form.address.trim()) {
      alert("Ingresá la dirección.");
      return;
    }

    try {
      setSaving(true);

      const payload = {
        ...form,
        nombre: form.name,
        apellido: form.last_name,
        telefono: form.phone,
        direccion: form.address,
        localidad: form.city,
        zona: form.zone,
        estado: form.status,
        username: form.pppoe_user,
        password: form.pppoe_password,
        ip_address: form.ip,
        plan_id: form.plan_id ? Number(form.plan_id) : null,
        router_id: form.router_id ? Number(form.router_id) : null,
      };

      if (form.id) {
        let saved = false;

        const attempts = [
          () => axios.put(`${API}/customers/${form.id}`, payload, getHeaders()),
          () => axios.patch(`${API}/customers/${form.id}`, payload, getHeaders()),
        ];

        for (const attempt of attempts) {
          try {
            await attempt();
            saved = true;
            break;
          } catch (err) {
            console.warn("Intento editar cliente falló:", err?.response?.status || err?.message);
          }
        }

        if (!saved) throw new Error("No se pudo editar cliente.");
      } else {
        let saved = false;

        const attempts = [
          () => axios.post(`${API}/customers`, payload, getHeaders()),
          () => axios.post(`${API}/customers/`, payload, getHeaders()),
        ];

        for (const attempt of attempts) {
          try {
            await attempt();
            saved = true;
            break;
          } catch (err) {
            console.warn("Intento crear cliente falló:", err?.response?.status || err?.message);
          }
        }

        if (!saved) throw new Error("No se pudo crear cliente.");
      }

      setShowForm(false);
      setForm(emptyForm);
      await loadClients();

      alert(form.id ? "Cliente actualizado correctamente." : "Cliente creado correctamente.");
    } catch (err) {
      console.error(err);
      alert("No se pudo guardar el cliente. Revisá los datos o el endpoint del backend.");
    } finally {
      setSaving(false);
    }
  };

  const changeClientStatus = async (client, action) => {
    const id = client.id || client.customer_id;

    if (!id) {
      alert("Este cliente no tiene ID.");
      return;
    }

    const label = action === "activate" ? "activar" : "suspender";
    const ok = confirm(`¿Querés ${label} a ${getFullName(client)}?`);

    if (!ok) return;

    try {
      setChangingId(id);

      const payload =
        action === "activate"
          ? { status: "active", estado: "Activo", active: true }
          : { status: "suspended", estado: "Suspendido", active: false };

      let saved = false;

      const attempts =
        action === "activate"
          ? [
              () => axios.post(`${API}/customers/${id}/activate`, {}, getHeaders()),
              () => axios.post(`${API}/customers/${id}/restore-service`, {}, getHeaders()),
              () => axios.patch(`${API}/customers/${id}`, payload, getHeaders()),
            ]
          : [
              () => axios.post(`${API}/customers/${id}/suspend`, {}, getHeaders()),
              () => axios.post(`${API}/customers/${id}/cut-service`, {}, getHeaders()),
              () => axios.patch(`${API}/customers/${id}`, payload, getHeaders()),
            ];

      for (const attempt of attempts) {
        try {
          await attempt();
          saved = true;
          break;
        } catch (err) {
          console.warn("Intento cambiar cliente falló:", err?.response?.status || err?.message);
        }
      }

      if (!saved) {
        alert("No se encontró endpoint para cambiar estado.");
        return;
      }

      await loadClients();
    } finally {
      setChangingId(null);
    }
  };

  return (
    <div className="hsm-clients-page">
      <section className="hsm-clients-head">
        <div>
          <h2>Clientes</h2>
          <p>{stats.total} clientes registrados</p>
        </div>

        <button onClick={openNewClient}>+ Cliente</button>
      </section>

      <section className="hsm-client-stats">
        <div>
          <strong>{stats.activos}</strong>
          <span>Activos</span>
        </div>

        <div>
          <strong>{stats.suspendidos}</strong>
          <span>Suspendidos</span>
        </div>

        <div>
          <strong>{stats.pendientes}</strong>
          <span>Otros</span>
        </div>
      </section>

      <section className="hsm-client-search">
        <input
          value={query}
          onChange={(e) => setQuery(e.target.value)}
          placeholder="Buscar cliente, teléfono o dirección..."
        />

        <div className="hsm-client-filter">
          <button
            className={statusFilter === "todos" ? "active" : ""}
            onClick={() => setStatusFilter("todos")}
          >
            Todos
          </button>

          <button
            className={statusFilter === "activo" ? "active" : ""}
            onClick={() => setStatusFilter("activo")}
          >
            Activos
          </button>

          <button
            className={statusFilter === "suspendido" ? "active" : ""}
            onClick={() => setStatusFilter("suspendido")}
          >
            Suspendidos
          </button>
        </div>
      </section>

      <button className="hsm-client-refresh" onClick={loadClients}>
        Actualizar lista
      </button>

      {showForm && (
        <section className="hsm-client-form-card">
          <div className="hsm-client-form-head">
            <h3>{form.id ? "Editar cliente" : "Nuevo cliente"}</h3>
            <button onClick={() => setShowForm(false)}>×</button>
          </div>

          <form onSubmit={saveClient} className="hsm-client-form">
            <input
              placeholder="Nombre"
              value={form.name}
              onChange={(e) => updateForm("name", e.target.value)}
            />

            <input
              placeholder="Apellido"
              value={form.last_name}
              onChange={(e) => updateForm("last_name", e.target.value)}
            />

            <input
              placeholder="DNI"
              value={form.dni}
              onChange={(e) => updateForm("dni", e.target.value)}
            />

            <input
              placeholder="Teléfono"
              value={form.phone}
              onChange={(e) => updateForm("phone", e.target.value)}
            />

            <input
              type="email"
              placeholder="Email"
              value={form.email}
              onChange={(e) => updateForm("email", e.target.value)}
            />

            <input
              placeholder="Dirección"
              value={form.address}
              onChange={(e) => updateForm("address", e.target.value)}
            />

            <input
              placeholder="Localidad"
              value={form.city}
              onChange={(e) => updateForm("city", e.target.value)}
            />

            <input
              placeholder="Zona / Barrio"
              value={form.zone}
              onChange={(e) => updateForm("zone", e.target.value)}
            />

            <select
              value={form.plan_id}
              onChange={(e) => updateForm("plan_id", e.target.value)}
            >
              <option value="">Seleccionar plan</option>
              {plans.map((plan) => (
                <option key={plan.id} value={plan.id}>
                  {getPlanLabel(plan)}
                </option>
              ))}
            </select>

            <select
              value={form.router_id}
              onChange={(e) => {
                updateForm("router_id", e.target.value);
                updateForm("ip_range", "");
                updateForm("ip", "");
                loadIpRanges(e.target.value);
              }}
            >
              <option value="">Seleccionar router</option>
              {routers.map((router) => (
                <option key={router.id} value={router.id}>
                  {getRouterLabel(router)}
                </option>
              ))}
            </select>

            <select
              value={form.ip_range}
              onChange={(e) => {
                updateForm("ip_range", e.target.value);

                const selected = ipRanges.find((range) => String(range.id || range.range || range.cidr || range.pool || range.network) === String(e.target.value));

                if (selected?.ip) updateForm("ip", selected.ip);
                if (selected?.address) updateForm("ip", selected.address);
                if (selected?.first_available_ip) updateForm("ip", selected.first_available_ip);
              }}
            >
              <option value="">Seleccionar rango / pool IP</option>
              {ipRanges.map((range, index) => (
                <option
                  key={range.id || range.range || range.cidr || index}
                  value={range.id || range.range || range.cidr || range.pool || range.network}
                >
                  {getIpRangeLabel(range)}
                </option>
              ))}
            </select>

            <input
              placeholder="Usuario PPPoE"
              value={form.pppoe_user}
              onChange={(e) => updateForm("pppoe_user", e.target.value)}
            />

            <input
              placeholder="Contraseña PPPoE"
              value={form.pppoe_password}
              onChange={(e) => updateForm("pppoe_password", e.target.value)}
            />

            <input
              placeholder="IP"
              value={form.ip}
              onChange={(e) => updateForm("ip", e.target.value)}
            />

            <select
              value={form.status}
              onChange={(e) => updateForm("status", e.target.value)}
            >
              <option value="Activo">Activo</option>
              <option value="Suspendido">Suspendido</option>
              <option value="Cortado">Cortado</option>
              <option value="Pendiente">Pendiente</option>
            </select>

            <textarea
              placeholder="Notas"
              value={form.notes}
              onChange={(e) => updateForm("notes", e.target.value)}
            />

            <button type="submit" disabled={saving}>
              {saving ? "Guardando..." : form.id ? "Guardar cambios" : "Crear cliente"}
            </button>
          </form>
        </section>
      )}

      {loading && (
        <div className="hsm-card">
          <p>Cargando clientes...</p>
        </div>
      )}

      {error && (
        <div className="hsm-card">
          <p style={{ color: "#dc2626", fontWeight: 800 }}>{error}</p>
        </div>
      )}

      {!loading && !error && filteredClients.length === 0 && (
        <div className="hsm-card">
          <p>No hay clientes para mostrar.</p>
        </div>
      )}

      <section className="hsm-client-list">
        {filteredClients.map((client) => {
          const name = getFullName(client);
          const phone = getPhone(client);
          const status = getStatus(client);
          const id = client.id || client.customer_id;
          const expanded = expandedId === id;

          const plan =
            client.plan_name ||
            client.plan ||
            client.plan_nombre ||
            client.service_plan ||
            "Sin plan";

          const address =
            client.address ||
            client.direccion ||
            client.location ||
            client.ubicacion ||
            "Sin dirección";

          const ip =
            client.ip ||
            client.ip_address ||
            client.pppoe_ip ||
            client.router_ip ||
            "";

          const user =
            client.pppoe_user ||
            client.username ||
            client.user ||
            "-";

          const cleanPhone = String(phone).replace(/\D/g, "");
          const busy = changingId === id;

          return (
            <article key={id || name} className="hsm-client-card">
              <div className="hsm-client-top">
                <div className="hsm-client-avatar">
                  {name.charAt(0).toUpperCase()}
                </div>

                <div className="hsm-client-main">
                  <h3>{name}</h3>
                  <span className={`hsm-status ${statusClass(status)}`}>
                    {status}
                  </span>
                </div>
              </div>

              <div className="hsm-client-info">
                <div>
                  <b>Plan</b>
                  <span>{plan}</span>
                </div>

                <div>
                  <b>Teléfono</b>
                  <span>{phone || "Sin teléfono"}</span>
                </div>

                <div>
                  <b>Dirección</b>
                  <span>{address}</span>
                </div>

                {ip ? (
                  <div>
                    <b>IP</b>
                    <span>{ip}</span>
                  </div>
                ) : null}
              </div>

              {expanded && (
                <div className="hsm-client-details">
                  <div>
                    <b>ID</b>
                    <span>{id || "-"}</span>
                  </div>

                  <div>
                    <b>Usuario PPPoE</b>
                    <span>{user}</span>
                  </div>

                  <div>
                    <b>Email</b>
                    <span>{client.email || "-"}</span>
                  </div>

                  <div>
                    <b>DNI</b>
                    <span>{client.dni || client.document || "-"}</span>
                  </div>

                  <div className="full">
                    <b>Notas</b>
                    <span>{client.notes || client.observaciones || "-"}</span>
                  </div>
                </div>
              )}

              <div className="hsm-client-actions">
                {cleanPhone ? (
                  <a
                    href={`https://wa.me/${cleanPhone}`}
                    target="_blank"
                    rel="noreferrer"
                  >
                    WhatsApp
                  </a>
                ) : null}

                <button onClick={() => setExpandedId(expanded ? null : id)}>
                  {expanded ? "Ocultar" : "Detalle"}
                </button>

                <button onClick={() => openEditClient(client)}>
                  Editar
                </button>
              </div>

              <div className="hsm-client-actions second">
                <button onClick={() => changeClientStatus(client, "activate")} disabled={busy}>
                  Activar
                </button>

                <button className="danger" onClick={() => changeClientStatus(client, "suspend")} disabled={busy}>
                  Suspender
                </button>
              </div>
            </article>
          );
        })}
      </section>
    </div>
  );
}

export default MobileClients;
